# ---- Supabase (server-side) ----
# Use the SERVICE ROLE key here (NOT the anon/publishable key).
# This backend runs on a trusted server, never in the browser, so it's safe here.
# Get it from: Supabase Dashboard -> Project Settings -> API -> service_role key
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ---- Reddit (free, no approval needed) ----
# Create an app at https://www.reddit.com/prefs/apps (type: "script")
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=smi-tool-ultimate/1.0 by yourusername

# ---- YouTube Data API v3 ----
# Get a key from https://console.cloud.google.com/apis/credentials (enable "YouTube Data API v3")
YOUTUBE_API_KEY=

# ---- NewsAPI ----
# Get a free key from https://newsapi.org
NEWSAPI_KEY=

# ---- Twitter/X API v2 (paid tier required - developer.x.com) ----
TWITTER_BEARER_TOKEN=

# ---- Instagram Graph API (Business account connected to a Facebook Page) ----
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# ---- Facebook Graph API (only reads YOUR OWN Page's posts) ----
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# ---- LinkedIn Marketing API (needs Partner Program approval; own org's posts only) ----
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORG_URN=

# ---- TikTok Display API (own connected account's videos only) ----
TIKTOK_ACCESS_TOKEN=

# ---- Pinterest API v5 (own account's pins only) ----
PINTEREST_ACCESS_TOKEN=

# ---- Threads API (own account's posts only) ----
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=

# Snapchat: no env vars - there is no content-read API at all, always unavailable.

# ---- Amazon Product Advertising API v5 (needs an approved Associates account) ----
AMAZON_PAAPI_ACCESS_KEY=
AMAZON_PAAPI_SECRET_KEY=
AMAZON_PAAPI_PARTNER_TAG=
AMAZON_PAAPI_HOST=webservices.amazon.in
AMAZON_PAAPI_REGION=eu-west-1

# ---- Flipkart Affiliate API (needs an approved affiliate account) ----
FLIPKART_AFFILIATE_ID=
FLIPKART_AFFILIATE_TOKEN=

# Meesho, Myntra, Nykaa: no env vars - no public/self-serve API exists for any of them.

# ---- What to search for ----
# Comma-separated keywords collectors will search/track
SEARCH_KEYWORDS=your brand,your product

# ---- RSS feeds (comma-separated URLs), used by the RSS collector ----
RSS_FEED_URLS=https://feeds.bbci.co.uk/news/rss.xml,https://www.thehindu.com/news/national/feeder/default.rss
